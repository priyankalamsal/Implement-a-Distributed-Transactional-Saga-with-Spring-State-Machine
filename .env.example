# Database configuration
DB_NAME=saga_db
DB_USER=user
DB_PASSWORD=password

# Internal service URLs used by order-service
PAYMENT_SERVICE_URL=http://payment-service:8081
INVENTORY_SERVICE_URL=http://inventory-service:8082

# Deterministic order IDs used by the evaluator and downstream mocks
SUCCESSFUL_ORDER_ID=100
FAILING_PAYMENT_ORDER_ID=201
FAILING_INVENTORY_ORDER_ID=302

# Optional downstream client tuning
DOWNSTREAM_CONNECT_TIMEOUT_MS=2000
DOWNSTREAM_READ_TIMEOUT_MS=5000

# Optional payment delay used for the restart-persistence scenario
PAYMENT_DELAY_MS=0
